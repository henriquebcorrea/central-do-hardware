# Configurações do E-commerce (Central do Hardware)

# A URL base do projeto em produção
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# (Simulado) Chave de API da InfinitePay para processamento de pagamentos
# Em produção real, este valor viria do painel da InfinitePay.
# Para este projeto (modo simulado), qualquer valor pode ser usado ou mesmo deixado em branco.
INFINITEPAY_API_KEY="sk_test_123456789"
INFINITEPAY_ENV="sandbox" # sandbox | production

# Chave da API Groq para o chatbot de atendimento (https://console.groq.com)
GROQ_API_KEY="gsk_sua_chave_aqui"
GROQ_MODEL="llama-3.1-8b-instant" # Modelo Groq a ser utilizado
